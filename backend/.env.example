# Backend environment variables
# Copy to .env and fill values.  NEVER commit .env.

# Supabase (service role key — server only, never expose to frontend)
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# Discord bot token (leave empty to disable the bot)
DISCORD_TOKEN=

# Server
PORT=5000

# Frontend origin for CORS (e.g. http://localhost:5173 or your Vercel URL)
FRONTEND_ORIGIN=http://localhost:5173
# ============================================================
# OfficePulse — Root environment variables example
# Copy this file to `.env` in each subfolder and fill values.
# NEVER commit the real `.env` files.
# ============================================================

# Backend (see backend/.env.example)
# SUPABASE_URL=bcbsjbcsjbj
# DISCORD_TOKEN=ddkckhd
# PORT=5000
# FRONTEND_ORIGIN=dnnknck

# Frontend (see frontend/.env.example)
# VITE_API_BASE_URL=
# VITE_SOCKET_URL=
