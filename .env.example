# ============================================================
# OfficePulse — Root environment variables example
# Copy this file to `.env` in each subfolder and fill values.
# NEVER commit the real `.env` files.
# ============================================================

# Backend (see backend/.env.example)
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
# DISCORD_TOKEN=
# PORT=5000
# FRONTEND_ORIGIN=

# Frontend (see frontend/.env.example)
# VITE_API_BASE_URL=
# VITE_SOCKET_URL=
